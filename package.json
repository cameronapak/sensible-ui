{
  "name": "@faith-tools/sensible-ui",
  "version": "1.0.3",
  "description": "Imagining Shadcn UI styles by default via a semantic CSS UI library",
  "author": "cameronapak",
  "type": "module",
  "exports": {
    ".": [
      "./dist/sensible-ui.css",
      "./dist/sensible-ui.min.css"
    ],
    "./accordion": "./src/css/accordion.css",
    "./badge": "./src/css/badge.css",
    "./base": "./src/css/base.css",
    "./button": "./src/css/button.css",
    "./card": "./src/css/card.css",
    "./css": "./dist/sensible-ui.css",
    "./image": "./src/css/image.css",
    "./index": "./src/css/index.css",
    "./item": "./src/css/item.css",
    "./spinner": "./src/css/spinner.css",
    "./table": "./src/css/table.css",
    "./theme": "./src/css/theme.css",
    "./typography": "./src/css/typography.css",
    "./utils": "./src/css/utils.css"
  },
  "keywords": [
    "components",
    "component library",
    "component system",
    "ui",
    "ui kit",
    "shadcn",
    "shadcn/ui",
    "tailwind",
    "tailwindcss",
    "css",
    "html"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cameronapak/sensible-ui.git"
  },
  "bugs": {
    "url": "https://github.com/cameronapak/sensible-ui/issues"
  },
  "homepage": "https://sensibleui.com",
  "scripts": {
    "dev": "bun run --hot ./index.tsx",
    "dev:css": "tailwindcss -i ./src/css/index.css -o ./dist/sensible-ui.css --watch",
    "build": "tailwindcss -i ./src/css/index.css -o ./dist/sensible-ui.min.css --minify",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.7",
    "@tailwindcss/cli": "^4.2.1",
    "@types/bun": "^1.3.10",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "bun-plugin-tailwind": "^0.1.2"
  }
}
