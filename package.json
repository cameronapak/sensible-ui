{
  "name": "semantics-ui",
  "version": "0.0.1",
  "description": "Imagining Shadcn UI styles by default via a semantic CSS UI library",
  "author": "cameronapak",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "components",
    "component library",
    "component system",
    "ui",
    "ui kit",
    "shadcn",
    "shadcn/ui",
    "tailwind",
    "tailwindcss",
    "css",
    "html"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cameronapak/semantics-ui.git"
  },
  "bugs": {
    "url": "https://github.com/cameronapak/semantics-ui/issues"
  },
  "homepage": "https://github.com/cameronapak/semantics-ui#readme",
  "scripts": {
    "dev": "concurrently -k \"bun run dev:server\" \"bun run dev:css\"",
    "dev:server": "bun ./index.ts",
    "dev:css": "tailwindcss -i ./src/css/index.css -o ./src/css/generated.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.3",
    "@types/bun": "^1.3.9",
    "concurrently": "^9.1.2",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.2.0",
    "terser": "^5.42.0"
  },
  "dependencies": {
    "bun-plugin-tailwind": "^0.1.2"
  }
}
